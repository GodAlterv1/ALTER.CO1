# Port for the API server (default: 3000)
PORT=3000

# Secret for JWT tokens — use a long random string in production.
# Keep the SAME value on every deploy; changing it invalidates all existing logins.
JWT_SECRET=your-secret-key-change-in-production

# Optional: directory for data files (default: backend/data)
# DB_PATH=./data

# ----- Email -----
# Render FREE tier blocks outbound SMTP (timeouts). Use Resend (HTTPS) instead of Gmail SMTP:
# https://resend.com — create API key, then:
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=onboarding@resend.dev
# (Later: verify your own domain in Resend and use e.g. noreply@yourdomain.com)
#
# ----- Email (Gmail SMTP — works locally or on paid hosts; not on Render free) -----
# Recommended for Gmail: create an App Password (Google Account → Security → 2-Step Verification → App passwords)
# and use it below — your normal Gmail password often will not work for SMTP.
SMTP_SERVICE=gmail
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-or-account-password
# Use the same Gmail as SMTP_USER, or Gmail may reject the send:
EMAIL_FROM=you@gmail.com

# Gmail on Render: default is port 587 (STARTTLS). If that fails, try:
# SMTP_GMAIL_MODE=465
# Or try nodemailer's built-in Gmail:
# SMTP_GMAIL_USE_SERVICE=true
# Verbose SMTP logs (Render logs):
# SMTP_DEBUG=true

# Where contact-form messages are delivered (defaults to SMTP_USER if unset)
# CONTACT_INBOX=you@gmail.com

# ----- Google Calendar OAuth (optional — enables “Connect Google Calendar” sync) -----
# Create OAuth 2.0 credentials: Google Cloud Console → APIs & Services → Credentials → Create credentials → OAuth client ID (Web application).
# Enable “Google Calendar API” for the same project.
# Authorized redirect URI must match exactly (example for local dev):
#   http://localhost:3000/auth/google/calendar/callback
# Production (your API host):
#   https://your-api.onrender.com/auth/google/calendar/callback
#
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_CLIENT_REDIRECT_URI=http://localhost:3000/auth/google/calendar/callback
#
# Optional: where to send the browser after OAuth (SPA). Defaults to same origin as the API.
# Use when the app is on a different host than the API (e.g. static site + API subdomain).
# FRONTEND_URL=https://your-app.example.com
#
# Optional: defaults to read-only calendar access.
# GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly

# Optional rate limits (per IP)
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_CONTACT_MAX=8

# Alternative: custom SMTP (omit SMTP_SERVICE or set to something other than gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=secret
