# Port for the API server (default: 3000)
PORT=3000

# Secret for JWT tokens - use a long random string in production
JWT_SECRET=your-secret-key-change-in-production

# Optional: directory for data files (default: backend/data)
# DB_PATH=./data

# ----- Email -----
# Render FREE tier blocks outbound SMTP (timeouts). Use Resend (HTTPS) instead of Gmail SMTP:
# https://resend.com — create API key, then:
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=onboarding@resend.dev
# (Later: verify your own domain in Resend and use e.g. noreply@yourdomain.com)
#
# ----- Email (Gmail SMTP — works locally or on paid hosts; not on Render free) -----
# Recommended for Gmail: create an App Password (Google Account → Security → 2-Step Verification → App passwords)
# and use it below — your normal Gmail password often will not work for SMTP.
SMTP_SERVICE=gmail
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-or-account-password
# Use the same Gmail as SMTP_USER, or Gmail may reject the send:
EMAIL_FROM=you@gmail.com

# Gmail on Render: default is port 587 (STARTTLS). If that fails, try:
# SMTP_GMAIL_MODE=465
# Or try nodemailer's built-in Gmail:
# SMTP_GMAIL_USE_SERVICE=true
# Verbose SMTP logs (Render logs):
# SMTP_DEBUG=true

# Where contact-form messages are delivered (defaults to SMTP_USER if unset)
# CONTACT_INBOX=you@gmail.com

# Optional rate limits (per IP)
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_CONTACT_MAX=8

# Alternative: custom SMTP (omit SMTP_SERVICE or set to something other than gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=secret
